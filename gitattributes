# Normalize line endings to LF in the repo regardless of OS checkout settings —
# this repo was created on Linux; without this, Windows checkouts (autocrlf=true)
# turn every source file into a noisy all-lines-changed diff on the first edit.
* text=auto eol=lf

*.ts    text eol=lf
*.tsx   text eol=lf
*.js    text eol=lf
*.mjs   text eol=lf
*.jsx   text eol=lf
*.json  text eol=lf
*.css   text eol=lf
*.md    text eol=lf
*.prisma text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.svg   text eol=lf

*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.woff  binary
*.woff2 binary

# Never diff the lockfile line-by-line — it's machine-generated noise.
package-lock.json -diff
