# SQLite via libSQL — local file for development
DATABASE_URL="file:./dev.db"
# DATABASE_AUTH_TOKEN= # only needed for a remote Turso/libSQL database

# Generate with: openssl rand -hex 32
SESSION_SECRET="replace-with-a-long-random-string"

# Optional — enables "units held + live market price" tracking mode.
# Without it, that mode just prompts users to enter values manually.
FINNHUB_API_KEY=
